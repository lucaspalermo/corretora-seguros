generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// Tabelas compartilhadas (Planos e Tenants)
// ============================================================

model Tenant {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  document   String   @default("")
  schemaName String   @unique @map("schema_name")
  planId     String   @map("plan_id")
  status     String   @default("active")
  settings   String?  @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  plan Plan @relation(fields: [planId], references: [id])

  @@map("tenants")
}

model Plan {
  id           String   @id @default(uuid())
  name         String
  maxUsers     Int      @map("max_users")
  maxPolicies  Int      @map("max_policies")
  maxStorageMb Int      @map("max_storage_mb")
  priceCents   Int      @map("price_cents")
  billingCycle String   @map("billing_cycle") @default("monthly")
  features     String?  @default("{}")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenants Tenant[]

  @@map("plans")
}

// ============================================================
// Tabelas por tenant (isoladas por tenantId)
// ============================================================

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  cpf          String?
  role         String   @default("viewer")
  status       String   @default("active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  seller        Seller?
  auditLogs     AuditLog[]
  notifications Notification[]
  refreshTokens RefreshToken[]

  @@index([tenantId])
  @@map("users")
}

model Client {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  name                String
  document            String
  documentType        String   @map("document_type")
  personType          String   @map("person_type")
  phone               String?
  email               String?
  addressStreet       String?  @map("address_street")
  addressNumber       String?  @map("address_number")
  addressComplement   String?  @map("address_complement")
  addressNeighborhood String?  @map("address_neighborhood")
  addressCity         String?  @map("address_city")
  addressState        String?  @map("address_state")
  addressZip          String?  @map("address_zip")
  status              String   @default("active")
  notes               String?
  lgpdConsentAt       DateTime? @map("lgpd_consent_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  policies    Policy[]
  receivables Receivable[]
  quotes      Quote[]

  @@index([tenantId])
  @@index([document])
  @@index([name])
  @@index([status])
  @@map("clients")
}

model Insurer {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  name                 String
  category             String
  defaultCommissionPct Float    @map("default_commission_pct")
  paymentMethod        String?  @map("payment_method")
  contactName          String?  @map("contact_name")
  contactPhone         String?  @map("contact_phone")
  contactEmail         String?  @map("contact_email")
  status               String   @default("active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  policies   Policy[]
  quoteItems QuoteItem[]

  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@map("insurers")
}

model Seller {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  userId               String?  @unique @map("user_id")
  name                 String
  cpf                  String
  defaultCommissionPct Float    @map("default_commission_pct")
  specialCommissionPct Float?   @map("special_commission_pct")
  phone                String?
  email                String?
  status               String   @default("active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user               User?               @relation(fields: [userId], references: [id])
  policies           Policy[]
  commissionPayments CommissionPayment[]

  @@index([tenantId])
  @@index([cpf])
  @@index([status])
  @@map("sellers")
}

model Policy {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  clientId            String   @map("client_id")
  insurerId           String   @map("insurer_id")
  sellerId            String   @map("seller_id")
  policyNumber        String   @map("policy_number")
  category            String
  type                String   @default("active")
  startDate           DateTime @map("start_date")
  endDate             DateTime? @map("end_date")
  renewalDate         DateTime? @map("renewal_date")
  premiumCents        Int      @map("premium_cents")
  paymentMethod       String   @map("payment_method")
  installments        Int      @default(1)
  brokerCommissionPct Float    @map("broker_commission_pct")
  sellerCommissionPct Float    @map("seller_commission_pct")
  autoRenew           Boolean  @default(false) @map("auto_renew")
  notes               String?
  metadata            String?  @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  cancelledAt         DateTime? @map("cancelled_at")

  client      Client       @relation(fields: [clientId], references: [id])
  insurer     Insurer      @relation(fields: [insurerId], references: [id])
  seller      Seller       @relation(fields: [sellerId], references: [id])
  receivables Receivable[]

  @@index([tenantId])
  @@index([policyNumber])
  @@index([clientId])
  @@index([insurerId])
  @@index([sellerId])
  @@index([category, type])
  @@index([endDate])
  @@index([renewalDate])
  @@map("policies")
}

model Receivable {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  policyId              String   @map("policy_id")
  clientId              String   @map("client_id")
  installmentNumber     Int      @map("installment_number")
  grossAmountCents      Int      @map("gross_amount_cents")
  brokerCommissionCents Int      @map("broker_commission_cents")
  sellerCommissionCents Int      @map("seller_commission_cents")
  netAmountCents        Int      @map("net_amount_cents")
  dueDate               DateTime @map("due_date")
  receivedDate          DateTime? @map("received_date")
  status                String   @default("pending")
  paymentProofUrl       String?  @map("payment_proof_url")
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  policy             Policy              @relation(fields: [policyId], references: [id])
  client             Client              @relation(fields: [clientId], references: [id])
  commissionPayments CommissionPayment[]

  @@index([tenantId])
  @@index([policyId])
  @@index([clientId])
  @@index([dueDate, status])
  @@index([status])
  @@index([receivedDate])
  @@map("receivables")
}

model CommissionPayment {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  sellerId     String    @map("seller_id")
  receivableId String    @map("receivable_id")
  amountCents  Int       @map("amount_cents")
  paidDate     DateTime? @map("paid_date")
  status       String    @default("pending")
  createdAt    DateTime  @default(now()) @map("created_at")

  seller     Seller     @relation(fields: [sellerId], references: [id])
  receivable Receivable @relation(fields: [receivableId], references: [id])

  @@index([tenantId])
  @@index([sellerId, paidDate])
  @@map("commission_payments")
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValues String?  @map("old_values")
  newValues String?  @map("new_values")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  entity    String?
  entityId  String?  @map("entity_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// Documentos / Anexos
// ============================================================

model Document {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  entity      String   // 'policy', 'client', 'quote'
  entityId    String   @map("entity_id")
  filename    String
  originalName String  @map("original_name")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  url         String
  category    String   @default("other") // 'proposal', 'policy_doc', 'receipt', 'id_doc', 'other'
  notes       String?
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([entity, entityId])
  @@map("documents")
}

// ============================================================
// Multicalculo (Cotacoes comparativas)
// ============================================================

model Quote {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  clientId       String    @map("client_id")
  sellerId       String    @map("seller_id")
  title          String    @default("")
  category       String
  status         String    @default("draft")
  riskData       String    @default("{}") @map("risk_data")
  expiresAt      DateTime? @map("expires_at")
  acceptedAt     DateTime? @map("accepted_at")
  acceptedItemId String?   @map("accepted_item_id")
  policyId       String?   @map("policy_id")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  client Client      @relation(fields: [clientId], references: [id])
  items  QuoteItem[]

  @@index([tenantId])
  @@index([clientId])
  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@map("quotes")
}

model QuoteItem {
  id                  String    @id @default(uuid())
  tenantId            String    @map("tenant_id")
  quoteId             String    @map("quote_id")
  insurerId           String    @map("insurer_id")
  premiumCents        Int       @map("premium_cents")
  installments        Int       @default(1)
  paymentMethod       String?   @map("payment_method")
  brokerCommissionPct Float     @map("broker_commission_pct")
  sellerCommissionPct Float     @default(0) @map("seller_commission_pct")
  coverages           String    @default("{}") @map("coverages")
  conditions          String    @default("{}") @map("conditions")
  selected            Boolean   @default(false)
  proposalNumber      String?   @map("proposal_number")
  validUntil          DateTime? @map("valid_until")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  insurer Insurer @relation(fields: [insurerId], references: [id])

  @@index([tenantId])
  @@index([quoteId])
  @@index([insurerId])
  @@map("quote_items")
}
